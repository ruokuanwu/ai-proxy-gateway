{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Launch Gateway",
            "type": "go",
            "request": "launch",
            "mode": "auto",
            "program": "${workspaceFolder}/cmd/gateway",
            "args": [
                "-config",
                "${workspaceFolder}/configs/config.json"
            ],
            "cwd": "${workspaceFolder}",
            "env": {
                "GIN_MODE": "debug"
            }
        }
    ]
}