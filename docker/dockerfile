# syntax=docker/dockerfile:1

FROM golang:1.22-alpine AS builder

WORKDIR /src

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN CGO_ENABLED=0 GOOS=linux GOARCH=amd64 go build -trimpath -ldflags="-s -w" -o /out/ai-proxy-gateway ./cmd/gateway

FROM gcr.io/distroless/static-debian12:nonroot

WORKDIR /

COPY --from=builder /out/ai-proxy-gateway /ai-proxy-gateway
COPY configs/config.example.json /config/config.json

EXPOSE 18080

USER nonroot:nonroot
ENTRYPOINT ["/ai-proxy-gateway"]
CMD ["-config", "/config/config.json"]